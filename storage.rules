
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read access for all files.
    // This is safe for public assets like the manifest and fallback plant images.
    match /{allPaths=**} {
      allow read;
    }

    // Allow users to write to their own folder.
    match /user/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
